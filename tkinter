import customtkinter as ctk  # Using customtkinter for modern UI
from tkinter import filedialog, ttk, messagebox  # Import the standard messagebox
import os
import time
import pandas as pd
import datetime

class App:
    def __init__(self, root):
        ctk.set_appearance_mode("dark")  # Modes: system (default), light, dark
        ctk.set_default_color_theme("blue")  # Themes: blue (default), dark-blue, green

        self.window = root
        self.window.title("Process Automation")
        self.window.geometry("1000x700")  # Increase window size

        # Configuring grid to make the Treeview auto-resizable
        self.window.grid_columnconfigure(1, weight=1)
        self.window.grid_rowconfigure(10, weight=1)  # Adjust grid to accommodate all buttons and frames

        # Checkbox variables
        self.checkbox1_var = ctk.BooleanVar()
        self.checkbox2_var = ctk.BooleanVar()

        # Checkboxes and buttons for Process 1
        self.checkbox1 = ctk.CTkCheckBox(self.window, text="Process 1", variable=self.checkbox1_var, command=self.toggle_browse1)
        self.checkbox1.grid(row=1, column=1, sticky="w", padx=10, pady=10)

        # "Browse" button for Process 1
        self.browse_button1 = ctk.CTkButton(self.window, text="Browse", command=self.browse_file1)
        self.browse_button1.grid(row=1, column=2, padx=10, pady=10)

        # Placeholder for the folder structure Treeview for Process 1 (initially empty)
        self.treeview1 = None

        # Checkbox and buttons for Process 2 (shifted down to row 3)
        self.checkbox2 = ctk.CTkCheckBox(self.window, text="Process 2", variable=self.checkbox2_var, command=self.toggle_browse2)
        self.checkbox2.grid(row=4, column=1, sticky="w", padx=10, pady=10)

        # "Browse" button for Process 2
        self.browse_button2 = ctk.CTkButton(self.window, text="Browse", command=self.browse_file2)
        self.browse_button2.grid(row=4, column=2, padx=10, pady=10)

        # Run, Clear All, and Cancel buttons (shifted to row 5)
        self.run_button = ctk.CTkButton(self.window, text="Run", command=self.run_processes)
        self.run_button.grid(row=6, column=1, padx=10, pady=10)

        self.clear_button = ctk.CTkButton(self.window, text="Clear All", command=self.clear_all)
        self.clear_button.grid(row=6, column=2, padx=10, pady=10)

        self.cancel_button = ctk.CTkButton(self.window, text="Cancel", command=self.window.quit)
        self.cancel_button.grid(row=6, column=3, padx=10, pady=10)

        # Initialize file path variables
        self.filepath1 = ""
        self.filepath2 = ""

        # Treeview for folder structure for Process 2
        self.treeview2 = None

    def toggle_browse1(self):
        if self.checkbox1_var.get():
            # Create Treeview for Process 1 if not exists
            if not self.treeview1:
                self.treeview1 = ttk.Treeview(self.window)
                self.treeview1.grid(row=2, column=1, columnspan=3, padx=10, pady=10, sticky="nsew")
        else:
            if self.treeview1:
                self.treeview1.grid_remove()

    def toggle_browse2(self):
        if self.checkbox2_var.get():
            # Create Treeview for Process 2 if not exists
            if not self.treeview2:
                self.treeview2 = ttk.Treeview(self.window)
                self.treeview2.grid(row=5, column=1, columnspan=3, padx=10, pady=10, sticky="nsew")
        else:
            if self.treeview2:
                self.treeview2.grid_remove()

    def browse_file1(self):
        self.filepath1 = filedialog.askdirectory()
        if self.filepath1:
            if self.treeview1:
                self.treeview1.grid_remove()

            # Treeview for folder structure for Process 1, placed below Process 1's Browse button
            self.treeview1 = ttk.Treeview(self.window)
            self.treeview1.grid(row=2, column=1, columnspan=3, padx=10, pady=10, sticky="nsew")

            self.populate_treeview(self.treeview1, self.filepath1)
            self.expand_one_level(self.treeview1)  # Expand only one level by default

    def browse_file2(self):
        self.filepath2 = filedialog.askdirectory()
        if self.filepath2:
            if self.treeview2:
                self.treeview2.grid_remove()

            # Treeview for folder structure for Process 2
            self.treeview2 = ttk.Treeview(self.window)
            self.treeview2.grid(row=5, column=1, columnspan=3, padx=10, pady=10, sticky="nsew")

            self.populate_treeview(self.treeview2, self.filepath2)
            self.expand_one_level(self.treeview2)  # Expand only one level by default

    def populate_treeview(self, treeview, parent_dir):
        """Populate the treeview with directories and files"""
        treeview.heading("#0", text="Folder Structure", anchor='w')

        # Recursive function to add directories and files to the treeview
        def insert_node(parent, full_path):
            basename = os.path.basename(full_path)
            node = treeview.insert(parent, 'end', text=basename, open=False)
            if os.path.isdir(full_path):
                for item in os.listdir(full_path):
                    insert_node(node, os.path.join(full_path, item))
            elif full_path.endswith(".xlsx"):
                # Display sheet information for Excel files
                try:
                    excel_info = self.get_excel_info(full_path)
                    for sheet_info in excel_info:
                        treeview.insert(node, 'end', text=sheet_info)
                except Exception as e:
                    print(f"Error reading Excel file: {e}")

        insert_node("", parent_dir)

    def get_excel_info(self, filepath):
        """Gets the sheet name, row, and column count for each sheet in an Excel file."""
        xl = pd.ExcelFile(filepath)
        sheet_details = []
        for sheet_name in xl.sheet_names:
            df = xl.parse(sheet_name)
            sheet_info = f"Sheet: {sheet_name}, Columns: {df.shape[1]}, Rows: {df.shape[0]}"
            sheet_details.append(sheet_info)
        return sheet_details

    def expand_one_level(self, treeview):
        """Expand only one level of folders by default (keep files collapsed)."""
        def expand_first_level(node):
            for child in treeview.get_children(node):
                treeview.item(child, open=True)  # Expand only the first level (top-level folders)
        expand_first_level("")  # Start from the root node

    def run_processes(self):
        start_time = datetime.datetime.now()

        if self.checkbox1_var.get() and self.filepath1:
            self.run_process_on_tree(self.treeview1, self.filepath1)

        if self.checkbox2_var.get() and self.filepath2:
            self.run_process_on_tree(self.treeview2, self.filepath2)

        end_time = datetime.datetime.now()
        total_time = end_time - start_time
        total_time = total_time.total_seconds()
        total_time = divmod(total_time, 60)
        total_time = f"{int(total_time[0])} minutes {int(total_time[1])} seconds"
        messagebox.showinfo(title="Total Time", message=f"Total time taken: {total_time}")  # Use standard tkinter messagebox

    def run_process_on_tree(self, treeview, parent_dir):
        """Run process only on folder nodes (not files)."""
        def process_folder(node, folder_path):
            if os.path.isdir(folder_path):
                time.sleep(2)  # Simulate process running time
                print(f"Process completed for: {folder_path}")
                self.update_tree_item(treeview, node)  # Update tree for folders

        def process_tree(node, folder_path):
            process_folder(node, folder_path)
            for child in treeview.get_children(node):
                child_path = os.path.join(folder_path, treeview.item(child, 'text').replace('✓ ', ''))
                process_tree(child, child_path)

        root = treeview.get_children()[0]
        process_tree(root, parent_dir)

    def update_tree_item(self, treeview, node):
        """Update a tree item with a green checkmark (for folders only)."""
        text = treeview.item(node, 'text')
        if len(treeview.get_children(node)) > 0:  # Ensure it's a folder with children
            new_text = f"✓ {text}"
            treeview.item(node, text=new_text)
        self.window.update()

    def clear_all(self):
        self.checkbox1_var.set(False)
        self.checkbox2_var.set(False)
        self.filepath1 = ""
        self.filepath2 = ""

        if hasattr(self, 'browse_button1'):
            self.browse_button1.grid_remove()
        if hasattr(self, 'browse_button2'):
            self.browse_button2.grid_remove()

        if self.treeview1:
            self.treeview1.grid_remove()
        if self.treeview2:
            self.treeview2.grid_remove()


if __name__ == "__main__":
    root = ctk.CTk()
    app = App(root)
    root.mainloop()
