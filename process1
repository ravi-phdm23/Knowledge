import os

def run_for_each_folder(data_folder, output_folder):
    """
    Function to process data in the `data_folder` and store output in `output_folder`.
    Simulates processing by printing folder paths.
    """
    print(f"Processing data in: {data_folder}")
    print(f"Storing results in: {output_folder}")

    # Simulate processing with a simple example
    if os.path.exists(data_folder) and os.path.exists(output_folder):
        print(f"Successfully processed data from {data_folder} and saved output to {output_folder}.")
    else:
        print("Either data folder or output folder doesn't exist.")
