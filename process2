import os
import time

class Process2:
    def __init__(self, filepath):
        self.filepath = filepath

    def run(self):
        print(f"Starting Process 2 for the main directory: {self.filepath}")
        
        # Iterate over all directories inside the given filepath
        for root, dirs, files in os.walk(self.filepath):
            for dir_name in dirs:
                dir_path = os.path.join(root, dir_name)
                print(f"Running Process 2 in folder: {dir_path}")
                # Simulate process running time for each folder
                time.sleep(5)
                print(f"Process 2 completed for folder: {dir_path}")

        print("All folders processed.")

# Example usage:
