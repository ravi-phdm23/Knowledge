import pandas as pd
import os
import logging
logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')

# Define class for loading data
class DataLoader:
    def __init__(self, file_path, expected_columns, blank_defaults, expected_types):
        self.file_path = file_path
        self.expected_columns = expected_columns
        self.blank_defaults = blank_defaults
        self.expected_types = expected_types

    def load_data(self):
        df = pd.read_excel(self.file_path)
        for col, default in zip(self.expected_columns, self.blank_defaults):
            df[col] = df[col].fillna(default)
        return df

# Define class for saving data
class DataSaver:
    def __init__(self, output_file_path):
        self.output_file_path = output_file_path

    def save_data(self, df):
        df.to_excel(self.output_file_path, index=False)

# Define class for processing data
class DataProcessor:
    def __init__(self, source_info, output_info):
        self.source_info = source_info
        self.output_info = output_info
        self.dataframes = {}  # To store the loaded dataframes by data_frame_name

    def apply_direct_logic(self, df, output):
        """Apply direct logic to update output columns from the source dataframe and rename them."""
        for input_col, output_col, method, blank_default in zip(output['input_columns'], output['output_columns'], output['derivation_logic'], output['blank_default']):
            if method == 'direct':
                df[output_col] = df[input_col].fillna(blank_default)  # Populate output column with input data
                logging.info(f'Populated {output_col} using direct logic from {input_col}.')

                # Drop the original input column if it's being replaced
                if input_col != output_col:
                    df.drop(columns=[input_col], inplace=True)
        return df

    def apply_merge_logic(self, df, output):
        """Apply merge logic column by column and rename input columns to output columns, then drop right_on columns."""
        for output_col, method, merge_file, left_on, right_on, how, merge_input_col, blank_default in zip(
            output['output_columns'], output['derivation_logic'], output['Merge_Dataframe'], 
            output['left_on'], output['right_on'], output['how'], output['merge_mapping_columns'], output['blank_default']
        ):
            if method == 'merge' and merge_file != 'blank':
                # Load merge dataframe
                merge_df = pd.read_excel(f'data/mapping/{merge_file}.xlsx')
                
                # Check if the merge_input_col exists in merge_df
                if merge_input_col not in merge_df.columns:
                    logging.error(f'Column {merge_input_col} not found in {merge_file}')
                    continue
                
                # Perform the merge, using df as the left dataframe
                df = pd.merge(df, merge_df[[right_on, merge_input_col]], left_on=left_on, right_on=right_on, how=how)
                
                # After merge, rename merge_input_col to output_col
                if merge_input_col in df.columns:
                    df.rename(columns={merge_input_col: output_col}, inplace=True)
                    df[output_col] = df[output_col].fillna(blank_default)  # Ensure blanks are filled
                    logging.info(f'Populated and renamed {merge_input_col} to {output_col} using merge logic.')
                
                # Drop the 'right_on' column after the merge if it exists
                if right_on in df.columns:
                    df.drop(columns=[right_on], inplace=True)
                    logging.info(f'Dropped column {right_on} after merge.')
        return df

    def load_input_files(self):
        """Load input files once and store them in a dictionary by data_frame_name."""
        for info in self.source_info:
            file_path = info['input_file_path']
            df = DataLoader(file_path, info['columns'], info['blank_defaults'], info['types']).load_data()
            self.dataframes[info['data_frame_name']] = df
            logging.info(f'Loaded data from {file_path} into {info["data_frame_name"]}')

    def process_files(self):
        """Process each output file based on the pre-loaded input data."""
        for output in self.output_info:
            source_df_name = output['source_dataframe'][0]  # Get the source dataframe name for direct logic
            if source_df_name in self.dataframes:
                source_df = self.dataframes[source_df_name]  # Get the source dataframe
                output_df = source_df.copy()  # Create a copy of the source dataframe for processing

                # Apply direct logic to populate direct columns
                output_df = self.apply_direct_logic(output_df, output)

                # Apply merge logic column by column
                output_df = self.apply_merge_logic(output_df, output)

                # Save the final output dataframe
                DataSaver(output['output_file_path']).save_data(output_df)
                logging.info(f'Saved output to {output["output_file_path"]}')
            else:
                logging.error(f'Source dataframe {source_df_name} not found in loaded dataframes.')

